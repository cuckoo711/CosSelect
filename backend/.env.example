# Database (PostgreSQL in production, SQLite for quick local dev)
DATABASE_URL=postgresql+psycopg2://cosselect:cosselect@postgres:5432/cosselect

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Security - CHANGE THIS in production (long random string)
SECRET_KEY=change-me-to-a-long-random-secret

# Storage
DATA_DIR=/data/spaces

# Invite code TTL
INVITE_CODE_TTL_HOURS=24

# Inactivity auto-destroy: notice shown to leaders vs. actual server-side deletion
INACTIVE_NOTICE_DAYS=30
INACTIVE_DESTROY_DAYS=90
CLEANUP_INTERVAL_HOURS=24

# Thumbnail
THUMBNAIL_MAX_WIDTH=1200
THUMBNAIL_MAX_BYTES=512000
THUMBNAIL_QUALITY=82

# Uploaded image compression (server-side safety net, <=5 megapixels)
IMAGE_MAX_PIXELS=5000000
IMAGE_QUALITY=85

# CORS (comma separated, or * for all)
CORS_ORIGINS=*
