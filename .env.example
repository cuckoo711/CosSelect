# ---- Database ----
POSTGRES_USER=cosselect
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=cosselect

# ---- Security ----
# IMPORTANT: generate a long random value, e.g. `openssl rand -hex 32`
SECRET_KEY=change-this-to-a-long-random-secret

# ---- Invite code TTL (hours) ----
INVITE_CODE_TTL_HOURS=24

# ---- CORS (comma separated or *) ----
CORS_ORIGINS=*

# ---- Host port for the web (frontend/nginx) ----
HTTP_PORT=8080
